{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skeinrank.github.io/claim-plane/schemas/change-intent.schema.json",
  "title": "Claim Plane ChangeIntent v0.9",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_id",
    "owner",
    "base_revision",
    "operations"
  ],
  "properties": {
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "base_revision": {
      "type": "string",
      "minLength": 1
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/operation"
      }
    },
    "preserves": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "lease_seconds": {
      "type": "integer",
      "minimum": 1,
      "default": 900
    },
    "metadata": {
      "type": "object"
    },
    "base_commit": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-fA-F]{40,64}$"
    }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "access"
      ],
      "properties": {
        "access": {
          "enum": [
            "read",
            "write",
            "extend",
            "delete",
            "rename",
            "document",
            "test"
          ]
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "resource": {
          "$ref": "#/$defs/resource"
        },
        "kind": {
          "enum": [
            "file",
            "symbol",
            "concept",
            "contract",
            "document",
            "config",
            "route",
            "schema"
          ]
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "concept_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject_concept_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "type": "object"
        }
      },
      "oneOf": [
        {
          "required": [
            "resource"
          ]
        },
        {
          "required": [
            "kind",
            "identifier"
          ]
        }
      ]
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "identifier"
      ],
      "properties": {
        "kind": {
          "enum": [
            "file",
            "symbol",
            "concept",
            "contract",
            "document",
            "config",
            "route",
            "schema"
          ]
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "signature": {
          "type": [
            "string",
            "null"
          ]
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "concept_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject_concept_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "type": "object"
        }
      }
    }
  }
}
