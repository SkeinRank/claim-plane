{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skeinrank.github.io/claim-plane/schemas/change-manifest.schema.json",
  "title": "Claim Plane ChangeManifest v0.9",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_id",
    "owner",
    "base_revision",
    "changed_files"
  ],
  "properties": {
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "base_revision": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "changed_regions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "start_line",
          "end_line"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "start_line": {
            "type": "integer",
            "minimum": 0
          },
          "end_line": {
            "type": "integer",
            "minimum": 0
          },
          "old_start_line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "old_end_line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          }
        }
      }
    },
    "acceptance_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "returncode"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "returncode": {
            "type": "integer"
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          },
          "stdout_tail": {
            "type": "string"
          },
          "stderr_tail": {
            "type": "string"
          },
          "sandbox_backend": {
            "type": "string"
          },
          "sandbox_enforced": {
            "type": "boolean"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "identifier",
          "path"
        ],
        "properties": {
          "kind": {
            "enum": [
              "file",
              "symbol",
              "concept",
              "contract",
              "document",
              "config",
              "route",
              "schema"
            ]
          },
          "identifier": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "signature": {
            "type": [
              "string",
              "null"
            ]
          },
          "concept_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "subject_concept_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "qualified_identifier": {
            "type": [
              "string",
              "null"
            ]
          },
          "line_start": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "line_end": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    },
    "metadata": {
      "type": "object"
    },
    "base_commit": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-fA-F]{40,64}$"
    },
    "observed_accesses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mode",
          "resource"
        ],
        "properties": {
          "mode": {
            "enum": [
              "read",
              "write",
              "extend",
              "delete",
              "rename",
              "document",
              "test"
            ]
          },
          "resource": {
            "$ref": "change-intent.schema.json#/$defs/resource"
          },
          "tool": {
            "type": [
              "string",
              "null"
            ]
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ]
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
