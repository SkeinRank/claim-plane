{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skeinrank.github.io/claim-plane/schemas/integration-run.schema.json",
  "title": "Claim Plane IntegrationRunSpec v0.9",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "base_repo",
    "base_revision",
    "workers",
    "base_commit"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "base_repo": {
      "type": "string",
      "minLength": 1
    },
    "base_revision": {
      "type": "string",
      "minLength": 1
    },
    "workers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "intent_id",
          "repo_path"
        ],
        "properties": {
          "intent_id": {
            "type": "string",
            "minLength": 1
          },
          "repo_path": {
            "type": "string",
            "minLength": 1
          },
          "repair_command": {
            "type": [
              "string",
              "null"
            ]
          },
          "observation_trace": {
            "type": [
              "string",
              "null"
            ]
          },
          "observation_session_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "integration_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1
    },
    "repair_timeout": {
      "type": "integer",
      "minimum": 1
    },
    "integration_timeout": {
      "type": "integer",
      "minimum": 1
    },
    "run_worker_acceptance": {
      "type": "boolean"
    },
    "artifact_dir": {
      "type": "string",
      "minLength": 1
    },
    "keep_integration_worktree": {
      "type": "boolean"
    },
    "complete_on_success": {
      "type": "boolean"
    },
    "require_clean_worker_acceptance": {
      "type": "boolean"
    },
    "require_clean_integration_commands": {
      "type": "boolean"
    },
    "result_ref": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^refs/claim-plane/.+"
    },
    "base_commit": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-fA-F]{40,64}$"
    },
    "worker_sandbox": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "enum": [
            "tree",
            "auto",
            "bwrap",
            "bwrap-minimal",
            "sandbox-exec",
            "none"
          ]
        },
        "allow_network": {
          "type": "boolean"
        },
        "strict": {
          "type": "boolean"
        },
        "writable_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readable_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "environment_allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repository_writable": {
          "type": "boolean"
        }
      }
    },
    "integration_sandbox": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "enum": [
            "tree",
            "auto",
            "bwrap",
            "bwrap-minimal",
            "sandbox-exec",
            "none"
          ]
        },
        "allow_network": {
          "type": "boolean"
        },
        "strict": {
          "type": "boolean"
        },
        "writable_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readable_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "environment_allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repository_writable": {
          "type": "boolean"
        }
      }
    },
    "evidence_signing_key_env": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_key_id": {
      "type": "string",
      "minLength": 1
    },
    "repair_sandbox": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "enum": [
            "tree",
            "auto",
            "bwrap",
            "bwrap-minimal",
            "sandbox-exec",
            "none"
          ]
        },
        "allow_network": {
          "type": "boolean"
        },
        "strict": {
          "type": "boolean"
        },
        "writable_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readable_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "environment_allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repository_writable": {
          "type": "boolean"
        }
      }
    },
    "observation_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": [
            "optional",
            "required",
            "trusted",
            "brokered"
          ]
        },
        "require_complete": {
          "type": "boolean"
        },
        "allowed_coverages": {
          "type": "array",
          "items": {
            "enum": [
              "brokered_proxy",
              "tool_proxy",
              "os_monitor",
              "declared"
            ]
          }
        }
      }
    },
    "observation_key_env": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_signing_method": {
      "enum": [
        "hmac-sha256",
        "ed25519"
      ]
    },
    "broker_key_env": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
